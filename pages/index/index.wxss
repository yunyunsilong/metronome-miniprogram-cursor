.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f2f2f2;
}

.page {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 8rpx 20rpx 180rpx;
  background: #f2f2f2;
}

.card {
  background: #ffffff;
  border-radius: 18rpx;
  border: 1px solid #e8e8e8;
  padding: 14rpx;
}

.palette-card {
  margin: 18rpx 20rpx 20rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.06);
}

.palette-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.head-title {
  font-size: 40rpx;
  color: #a4acb8;
  font-weight: 700;
}

.mini-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f2f3f5;
  border-radius: 16rpx;
  border: 1px solid #e4e6ea;
  padding: 4rpx 10rpx;
}

.mini-label {
  font-size: 30rpx;
  color: #949daf;
  font-weight: 700;
}

.palette-toggle {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f8ef;
  border: 1px solid #bdeacc;
  border-radius: 50%;
}

.palette-toggle-icon {
  font-size: 24rpx;
  color: #08c160;
  font-weight: 700;
  line-height: 1;
}

.time-sig {
  padding-right: 14rpx;
}

.picker {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1d;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.palette-collapsed-tip {
  font-size: 24rpx;
  color: #9aa3b1;
  font-weight: 600;
  padding: 8rpx 4rpx 2rpx;
}

.tool-btn {
  min-height: 116rpx;
  background: #f1f1f1;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 2rpx;
}

.tool-btn-combo {
  min-height: 136rpx;
}

.tool-btn-active {
  background: #08c160;
}

.tool-symbol {
  font-size: 40rpx;
  color: #252525;
}

.tool-icon {
  width: 52rpx;
  height: 52rpx;
}

.tool-icon-wide-ultra {
  width: 124rpx;
  height: 64rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.tool-beat {
  margin-top: 2rpx;
  font-size: 18rpx;
  color: #8f98a7;
  font-weight: 700;
}

.tool-btn-active .tool-symbol,
.tool-btn-active .tool-beat {
  color: #ffffff;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 18rpx 6rpx 10rpx;
}

.section-title {
  font-size: 40rpx;
  color: #98a2b6;
  font-weight: 700;
}

.add-track {
  font-size: 38rpx;
  color: #08c160;
  font-weight: 700;
  background: #dcf4e9;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}

.track-card {
  margin-top: 12rpx;
  border-radius: 18rpx;
  border: 1px solid #d8dde7;
  background: #ffffff;
  padding: 14rpx;
}

.track-card-active {
  border: 2rpx solid #08c160;
  box-shadow: 0 6rpx 16rpx rgba(8, 193, 96, 0.1);
}

.track-card-skipped {
  background: #f3f4f6;
  border-color: #d7dce5;
}

.track-card-skipped .track-name,
.track-card-skipped .playing-tag,
.track-card-skipped .op-btn,
.track-card-skipped .loop-label,
.track-card-skipped .loop-op,
.track-card-skipped .loop-count,
.track-card-skipped .note-text,
.track-card-skipped .beat-mark {
  color: #a2a9b8;
  background-color: transparent;
}

.track-card-skipped .playing-tag {
  background: #a2a9b8;
}

.track-card-skipped .timeline {
  background: #eef1f5;
  border-color: #dde2ea;
}

.track-card-skipped .timeline-progress {
  background: rgba(148, 163, 184, 0.2);
}

.track-card-skipped .beat-divider {
  background: rgba(148, 163, 184, 0.5);
}

.track-card-skipped .note-chip {
  background: #f6f7fa;
  border-color: #e3e7ee;
}

.track-card-skipped .note-icon {
  opacity: 0.35;
}

.track-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.track-left {
  display: flex;
  align-items: center;
}

.track-name {
  font-size: 40rpx;
  color: #08c160;
  font-weight: 800;
  text-transform: uppercase;
}

.playing-tag {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #08c160;
  margin-left: 8rpx;
}

.track-ops {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.op-btn {
  font-size: 30rpx;
  color: #96a0b2;
  background: #f1f2f4;
  border-radius: 10rpx;
  padding: 8rpx 10rpx;
}

.op-btn-skip-active {
  color: #6b7280;
  background: #e5e7eb;
}

.delete {
  color: #dd4f59;
}

.loop-control {
  display: flex;
  align-items: center;
  background: #f1f2f4;
  border-radius: 10rpx;
  overflow: hidden;
}

.loop-label {
  font-size: 30rpx;
  color: #96a0b2;
  padding: 8rpx 10rpx;
}

.loop-box {
  display: flex;
  align-items: center;
  background: #e9ecf1;
  padding: 0 6rpx;
  height: 100%;
}

.loop-op {
  font-size: 30rpx;
  color: #96a0b2;
  width: 26rpx;
  text-align: center;
}

.loop-count {
  font-size: 30rpx;
  color: #616b7d;
  min-width: 22rpx;
  text-align: center;
}

.timeline {
  position: relative;
  margin-top: 12rpx;
  height: 112rpx;
  background: #f7f7f7;
  border-radius: 14rpx;
  border: 1px solid #e7e9ef;
  overflow: hidden;
}

.timeline-progress {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  background: rgba(8, 193, 96, 0.12);
}

.beat-divider {
  position: absolute;
  top: 4rpx;
  bottom: 4rpx;
  width: 3rpx;
  background: rgba(107, 114, 128, 0.58);
  z-index: 1;
}

.beat-mark {
  position: absolute;
  bottom: 2rpx;
  left: 8rpx;
  font-size: 20rpx;
  color: #b5bccb;
  font-weight: 700;
  z-index: 2;
}

.note-chip {
  position: absolute;
  top: 22rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f4fbf7 100%);
  border: 1px solid #cfe7d8;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: transform 100ms ease, box-shadow 100ms ease, border-color 100ms ease, background-color 100ms ease;
}

.note-rest {
  background: linear-gradient(180deg, #f8f9fb 0%, #edf1f5 100%);
  border-color: #d9e0e8;
}

.note-playing {
  border-color: #ef4444;
  box-shadow: 0 0 0 2rpx rgba(239, 68, 68, 0.16);
  transform: none;
}

.note-fill {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: rgba(239, 68, 68, 0.18);
}

.note-fill-active {
  background: rgba(239, 68, 68, 0.24);
}

.note-text {
  position: relative;
  z-index: 1;
  color: #1d9d5d;
  font-size: 50rpx;
  font-weight: 700;
}

.note-icon {
  position: relative;
  z-index: 1;
  width: 52rpx;
  height: 52rpx;
}

.footer-tip {
  margin: 66rpx 0 10rpx;
  text-align: center;
  font-size: 34rpx;
  color: #c8ced9;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 22rpx;
  height: 96rpx;
  border-radius: 18rpx;
  border: 1px solid #d8dde5;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 8rpx;
  z-index: 50;
}

.play-btn {
  width: 68rpx;
  height: 80rpx;
  border-radius: 14rpx;
  background: #08c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn-stop {
  background: #ef4444;
}

.play-icon {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.play-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.bpm-box {
  flex: 1;
  margin: 0 8rpx;
  height: 80rpx;
  border-radius: 14rpx;
  background: #f1f2f4;
  border: 1px solid #e3e5ea;
  display: flex;
  align-items: center;
}

.bpm-op {
  width: 58rpx;
  text-align: center;
  font-size: 36rpx;
  color: #98a0ae;
  font-weight: 700;
}

.bpm-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.1;
}

.bpm-num {
  font-size: 50rpx;
  color: #141414;
  font-weight: 800;
}

.bpm-input {
  width: 140rpx;
  text-align: center;
  background: transparent;
  padding: 0;
  line-height: 1.1;
}

.bpm-unit {
  font-size: 24rpx;
  color: #8e98ab;
  font-weight: 700;
}

.preset-entry {
  width: 186rpx;
  height: 80rpx;
  border-radius: 14rpx;
  background: #f1f2f4;
  border: 1px solid #e3e5ea;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.preset-icon {
  font-size: 28rpx;
  color: #08c160;
}

.preset-text {
  font-size: 30rpx;
  color: #111111;
  font-weight: 700;
  white-space: nowrap;
  line-height: 1;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
  display: flex;
  align-items: flex-end;
  z-index: 99;
}

.modal {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 22rpx;
  max-height: 70vh;
}

.modal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  color: #1f2937;
  font-weight: 700;
}

.modal-close {
  font-size: 28rpx;
  color: #6b7280;
}

.preset-list {
  margin-top: 12rpx;
  max-height: 54vh;
}

.preset-item {
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  margin-bottom: 10rpx;
}

.preset-name {
  display: block;
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
}

.preset-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6b7280;
}

/* Claude-inspired editorial warm theme overrides */
.page-root,
.page {
  background: #f7f3ee;
}

.card,
.track-card,
.bottom-bar,
.modal {
  background: #fffdfa;
  border-color: #e7ddd2;
  box-shadow: 0 8rpx 20rpx rgba(114, 84, 57, 0.09);
  border-radius: 14rpx;
}

.palette-card {
  margin: 22rpx 22rpx 16rpx;
  padding: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(114, 84, 57, 0.1);
}

.head-title,
.section-title,
.track-name,
.preset-text,
.modal-title,
.bpm-num,
.preset-name,
.picker {
  color: #3f3026;
  letter-spacing: 0.2rpx;
}

.track-name,
.add-track,
.preset-icon,
.palette-toggle-icon {
  color: #b06143;
}

.add-track,
.palette-toggle {
  background: #f4e7df;
  border-color: #dfc8b9;
}

.mini-control,
.op-btn,
.loop-control,
.bpm-box,
.preset-entry {
  background: #f9f3ec;
  border-color: #eadfd3;
  border-radius: 8rpx;
}

.loop-box {
  background: #f3ece4;
}

.mini-label,
.op-btn,
.loop-label,
.loop-op,
.loop-count,
.bpm-unit,
.preset-meta,
.beat-mark,
.footer-tip,
.modal-close {
  color: #8f7868;
  line-height: 1.35;
}

.tool-btn {
